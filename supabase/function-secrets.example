# Configure these through the Supabase Dashboard or `supabase secrets set`.
# Do not copy real values into this file or commit them to Git.

WEBHOOK_SECRET=<secret-used-by-n8n-for-ingest-run>
ADMIN_INVITE_SECRET=<secret-used-by-operator-tooling-for-invite-client>
SITE_URL=https://your-environment.example.com/
INVITE_REDIRECT_URL=https://your-environment.example.com/accept-invite

# Supabase supplies SUPABASE_URL and service credentials to deployed functions.
# Rotate these custom secrets separately for staging and production.
