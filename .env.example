# Browser-safe Supabase configuration.
# Copy this file to .env.local and replace the placeholders.
# Never put service-role keys, webhook secrets, admin secrets, or n8n API keys here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional browser analytics. The PostHog project token is public by design.
# Do not put private API keys here.
VITE_POSTHOG_PROJECT_TOKEN=phc_your-project-token
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional browser error reporting. The Sentry DSN is public by design.
VITE_SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/000000
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0
