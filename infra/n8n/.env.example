# Copy to .env on the n8n host. Generate every secret with a password manager.
N8N_VERSION=replace-with-reviewed-n8n-version
N8N_HOST=n8n.example.com
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-long-random-password
N8N_ENCRYPTION_KEY=replace-with-32-plus-character-random-key
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-long-random-key
EXECUTIONS_DATA_MAX_AGE=336
GENERIC_TIMEZONE=Asia/Kolkata

# Store these in n8n credentials or variables after deployment, never in Git.
SUPABASE_INGEST_URL=https://your-project.supabase.co/functions/v1/ingest-run
WEBHOOK_SECRET=
